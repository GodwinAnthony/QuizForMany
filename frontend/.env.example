# ---------------------------------------------------------------------------
# QuizPulse — frontend environment variables (Vite)
# ---------------------------------------------------------------------------
# Copy this file to `.env` for local overrides. In production (Render),
# set these in the service's Environment tab BEFORE running the build.
#
# Values that begin with VITE_* are inlined into the built bundle at
# `npm run build` time — they are NOT read at runtime. If you deploy
# and change VITE_API_URL, you must rebuild.
# ---------------------------------------------------------------------------

# Backend base URL used for both REST calls and Socket.IO.
#   • Leave BLANK (or unset) for same-origin deployments — the frontend
#     will use window.location.origin at runtime. This is the recommended
#     setup on Render when the backend also serves the built frontend
#     (single-service deployment).
#   • Set to your backend URL (e.g. https://quizpulse-api.onrender.com)
#     when the frontend is deployed as a separate static site.
#
# VITE_API_URL is the preferred name; VITE_SERVER_URL is honoured as a
# legacy alias so older `.env` files keep working.
VITE_API_URL=
# VITE_SERVER_URL=

# Optional — where the Vite dev-server proxy forwards /api and /socket.io
# during `npm run dev`. Only used locally.
# VITE_DEV_PROXY_TARGET=http://localhost:4000
