# ---------------------------------------------------------------------------
# QuizPulse — backend environment variables
# ---------------------------------------------------------------------------
# Copy to `.env` for local overrides. On Render, set these in the
# service's Environment tab.
# ---------------------------------------------------------------------------

# Port the HTTP server listens on.
#   • LOCAL: defaults to 4000 if unset.
#   • RENDER: DO NOT SET this manually — Render injects PORT and expects
#     the process to bind to it. The server reads process.env.PORT
#     automatically.
PORT=4000

# Bind address. Leave as 0.0.0.0 for any containerised / cloud deployment
# so the platform can route external traffic to the process.
HOST=0.0.0.0

# CORS allow-list for BOTH the REST API and Socket.IO.
#   • Unset or empty → local dev origins (localhost:5173) plus any
#     *.onrender.com host are auto-allowed. This is the recommended
#     setting for single-service Render deployments.
#   • "*"            → allow every origin (fine for a fully public API).
#   • Comma-separated list of exact origins, e.g.:
#       CORS_ORIGIN=https://quizpulse.onrender.com,https://quiz.example.com
CORS_ORIGIN=
